<title>Carolina de Insausti · Alta Costura Artesanal</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cinzel:wght@300;400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --blush:#f0e6df;--rose:#d4a89a;--rose-deep:#b07060;
  --ivory:#faf6f0;--champ:#e8ddd0;--sage:#c8c5b5;
  --gold:#c9a86c;--gold-l:#e8d5a8;
  --dk:#3a2f2a;--mid:#6b5548;--lt:#9a8578
}
html{scroll-behavior:smooth}
body{font-family:'Cormorant Garamond',Georgia,serif;background:var(--ivory);color:var(--dk);overflow-x:hidden}

nav{position:sticky;top:0;z-index:200;display:flex;justify-content:space-between;align-items:center;padding:16px 48px;background:rgba(250,246,240,.96);backdrop-filter:blur(14px);border-bottom:.5px solid rgba(180,150,130,.18)}
.nb{font-family:'Cinzel',serif;font-size:11px;letter-spacing:3px;color:var(--dk);font-weight:300}
.nl{display:flex;gap:28px}
.nl a{font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;color:var(--mid);text-transform:uppercase;text-decoration:none;transition:color .2s}
.nl a:hover{color:var(--rose-deep)}
.nav-menu{display:none;font-size:20px;cursor:pointer;color:var(--dk);background:none;border:none}

.hero{min-height:100vh;background:linear-gradient(160deg,#faf3ee,#f0e4d8 50%,#ebe0d2);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:110px 40px 80px;text-align:center;position:relative;overflow:hidden}
.halo{position:absolute;border-radius:50%;background:radial-gradient(circle,#d4a89a,transparent 70%);pointer-events:none}
.badge{font-family:'Cinzel',serif;font-size:9px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:18px}
.htitle{font-family:'Cinzel',serif;font-size:clamp(42px,8vw,90px);font-weight:300;letter-spacing:5px;line-height:1.02;margin-bottom:6px}
.hsub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(18px,3vw,32px);color:var(--rose-deep);letter-spacing:2px;margin-bottom:24px}
.orn{display:flex;align-items:center;gap:10px;justify-content:center;margin:0 0 24px}
.orn::before,.orn::after{content:'';width:90px;height:.5px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.dm{width:5px;height:5px;background:var(--gold);transform:rotate(45deg);flex-shrink:0}
.htxt{font-size:clamp(14px,1.8vw,18px);font-style:italic;color:var(--mid);line-height:2;max-width:450px;margin:0 auto 44px}
.ctarow{display:flex;gap:16px;flex-wrap:wrap;justify-content:center}
.btndk{font-family:'Cinzel',serif;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--ivory);background:var(--dk);border:none;padding:15px 34px;cursor:pointer;transition:background .3s}
.btndk:hover{background:var(--rose-deep)}
.btnot{font-family:'Cinzel',serif;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--dk);background:transparent;border:.5px solid var(--dk);padding:15px 34px;cursor:pointer;transition:background .3s}
.btnot:hover{background:var(--blush)}

.strip{background:var(--dk);padding:15px 40px;display:flex;justify-content:center;align-items:center;gap:36px;flex-wrap:wrap}
.si{font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;color:var(--gold-l);text-transform:uppercase;opacity:.85}
.sd{width:3px;height:3px;background:var(--gold);border-radius:50%;opacity:.4}

.sec{padding:88px 40px}
.sl{font-family:'Cinzel',serif;font-size:9px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;text-align:center;margin-bottom:13px}
.st{font-family:'Cinzel',serif;font-size:clamp(22px,4vw,42px);font-weight:300;letter-spacing:3px;text-align:center;margin-bottom:13px;line-height:1.25}
.sp{font-size:clamp(14px,1.8vw,17px);font-style:italic;color:var(--mid);line-height:2;text-align:center;max-width:520px;margin:0 auto 52px}

.hero-img-wrap{position:relative;overflow:hidden}
.hero-img{width:100%;height:88vh;object-fit:cover;object-position:center 20%;display:block}
.hero-caption{position:absolute;bottom:0;left:0;right:0;padding:60px 52px 36px;background:linear-gradient(transparent,rgba(30,20,15,.58))}
.hero-caption h2{font-family:'Cinzel',serif;font-size:clamp(24px,4vw,52px);font-weight:300;letter-spacing:4px;color:#faf6f0;margin-bottom:6px}
.hero-caption p{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(14px,2vw,20px);color:rgba(250,246,240,.8)}

.masonry{columns:3;column-gap:4px;max-width:1200px;margin:0 auto}
.mi{break-inside:avoid;margin-bottom:4px;overflow:hidden;cursor:pointer;position:relative}
.mi img{width:100%;display:block;transition:transform .55s ease}
.mi:hover img{transform:scale(1.05)}
.mcap{position:absolute;bottom:0;left:0;right:0;padding:20px 16px 13px;background:linear-gradient(transparent,rgba(30,20,15,.65));opacity:0;transition:opacity .3s;display:flex;flex-direction:column;gap:3px}
.mi:hover .mcap{opacity:1}
.mcat{font-family:'Cinzel',serif;font-size:7px;letter-spacing:2px;color:var(--gold-l);text-transform:uppercase}
.mname{font-family:'Cormorant Garamond',serif;font-size:14px;font-style:italic;color:#faf6f0}

.ed-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;max-width:1100px;margin:0 auto}
.ec{position:relative;overflow:hidden;cursor:pointer}
.ec img{width:100%;aspect-ratio:3/4;object-fit:cover;display:block;transition:transform .6s}
.ec:hover img{transform:scale(1.05)}
.eov{position:absolute;inset:0;background:linear-gradient(180deg,transparent 42%,rgba(30,20,15,.72) 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:26px 22px;opacity:0;transition:opacity .3s}
.ec:hover .eov{opacity:1}
.etag{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:var(--gold);text-transform:uppercase;margin-bottom:5px}
.ename{font-family:'Cinzel',serif;font-size:18px;font-weight:300;letter-spacing:2px;color:#faf6f0;margin-bottom:5px}
.edesc{font-size:13px;font-style:italic;color:rgba(250,246,240,.82);line-height:1.7}

.split{display:grid;grid-template-columns:1fr 1fr;max-width:1100px;margin:0 auto}
.split-img{overflow:hidden}
.split-img img{width:100%;height:100%;min-height:500px;object-fit:cover;display:block;transition:transform .55s}
.split-img:hover img{transform:scale(1.04)}
.split-txt{background:var(--dk);display:flex;flex-direction:column;justify-content:center;padding:64px 56px}
.split-txt .sl{text-align:left;margin-bottom:12px}
.split-txt h2{font-family:'Cinzel',serif;font-size:clamp(20px,2.8vw,34px);font-weight:300;letter-spacing:2px;color:var(--ivory);line-height:1.4;margin-bottom:22px}
.split-txt p{font-size:16px;font-style:italic;color:var(--sage);line-height:2;margin-bottom:12px}

.baby-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;max-width:1100px;margin:0 auto}
.bc{overflow:hidden;position:relative;cursor:pointer}
.bc img{width:100%;aspect-ratio:4/5;object-fit:cover;display:block;transition:transform .55s}
.bc:hover img{transform:scale(1.06)}
.bc-cap{position:absolute;bottom:0;left:0;right:0;padding:16px 14px 10px;background:linear-gradient(transparent,rgba(30,20,15,.6));opacity:0;transition:opacity .3s}
.bc:hover .bc-cap{opacity:1}
.bc-name{font-family:'Cormorant Garamond',serif;font-size:13px;font-style:italic;color:#faf6f0}

.pil-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;max-width:900px;margin:0 auto;text-align:center}
.pnum{font-family:'Cinzel',serif;font-size:30px;font-weight:300;color:var(--gold);opacity:.42;margin-bottom:8px}
.pname{font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;color:var(--dk);margin-bottom:9px}
.pdesc{font-size:14px;font-style:italic;color:var(--lt);line-height:1.9}

.fairs{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;max-width:680px;margin:0 auto 44px}
.fair{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:var(--gold-l);border:.5px solid rgba(201,168,108,.3);padding:10px 20px;text-transform:uppercase}

.ctform{max-width:480px;margin:0 auto;display:flex;flex-direction:column;gap:12px}
.ctform input,.ctform textarea,.ctform select{font-family:'Cormorant Garamond',serif;font-size:15px;font-style:italic;background:#fff;border:.5px solid var(--rose);color:var(--dk);padding:13px 17px;width:100%;outline:none}
.ctform textarea{resize:vertical;min-height:88px}
.ctform input::placeholder,.ctform textarea::placeholder{color:var(--lt)}

footer{background:var(--dk);padding:44px 40px;display:flex;flex-direction:column;align-items:center;gap:18px}
.fb{font-family:'Cinzel',serif;font-size:13px;letter-spacing:4px;color:var(--ivory);font-weight:300}
.fl{display:flex;gap:26px;flex-wrap:wrap;justify-content:center}
.fl span{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:var(--sage);text-transform:uppercase;cursor:pointer}
.fc{font-size:11px;font-style:italic;color:var(--lt);opacity:.5}

.lb{display:none;position:fixed;inset:0;background:rgba(18,10,7,.96);z-index:999;align-items:center;justify-content:center;flex-direction:column}
.lb.on{display:flex}
.lb img{max-width:88vw;max-height:84vh;object-fit:contain}
.lbx{position:absolute;top:22px;right:30px;font-size:22px;color:var(--gold);cursor:pointer;opacity:.75;font-family:'Cinzel',serif;line-height:1}
.lbx:hover{opacity:1}
.lbp,.lbn{position:absolute;top:50%;transform:translateY(-50%);font-size:36px;color:var(--gold);cursor:pointer;opacity:.5;padding:20px;user-select:none}
.lbp:hover,.lbn:hover{opacity:1}
.lbp{left:8px}.lbn{right:8px}
.lbcap{margin-top:14px;font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;color:var(--gold-l);text-transform:uppercase;opacity:.7}

@media(max-width:900px){
  .masonry{columns:2}
  .ed-grid{grid-template-columns:1fr 1fr}
  .pil-grid{grid-template-columns:1fr 1fr;gap:28px}
  .baby-grid{grid-template-columns:1fr 1fr}
  .split{grid-template-columns:1fr}
}
@media(max-width:580px){
  .masonry{columns:1}
  .ed-grid{grid-template-columns:1fr}
  nav{padding:14px 20px}
  .nl{gap:14px}
  .hero{padding:90px 24px 60px}
  .sec{padding:60px 24px}
  .split-txt{padding:44px 28px}
}
</style>
</head>
