  <span class="lbp" onclick="lbNav(-1)">‹</span>
  <img id="lbImg" src="" alt="">
  <div class="lbcap" id="lbCap"></div>
  <span class="lbn" onclick="lbNav(1)">›</span>
</div>

<script>
const lbImgs=[
  'https://i.ibb.co/N2n0x3XJ/IMG-9732.jpg',
  'https://i.ibb.co/C5F7sV4c/IMG-9716.jpg',
  'https://i.ibb.co/PsWGBQn8/IMG-9731.jpg',
  'https://i.ibb.co/zT3x2ffP/IMG-9729.jpg',
  'https://i.ibb.co/4qpvWVX/IMG-9730.jpg',
  'https://i.ibb.co/gbmXtzs1/IMG-9725.jpg',
  'https://i.ibb.co/6J17yhcs/IMG-9727.jpg',
  'https://i.ibb.co/ZzBNHqGt/IMG-9726.jpg',
  'https://i.ibb.co/7xVCc1fx/IMG-9714.jpg',
  'https://i.ibb.co/zTGh0YHL/IMG-9710.jpg',
  'https://i.ibb.co/632CdwV/IMG-9713.jpg',
  'https://i.ibb.co/0RJ7Szss/IMG-9728.jpg'
];
const lbNames=[
  'Arpa de hielo','La reina del kiosco','Nieve azul','Sueño lila',
  'Jardín de almendros','La bibliotecaria','Magia de estrellas','Encaje dorado',
  'Terciopelo rojo','Rosa de invierno','Encaje y perlas','Tul champagne'
];
let lbIdx=0;
function openLb(i){
  lbIdx=i;
  document.getElementById('lbImg').src=lbImgs[i];
  document.getElementById('lbCap').textContent=lbNames[i];
  document.getElementById('lb').classList.add('on');
}
function closeLb(){document.getElementById('lb').classList.remove('on')}
function lbNav(d){openLb((lbIdx+d+lbImgs.length)%lbImgs.length)}
document.getElementById('lb').addEventListener('click',e=>{if(e.target===e.currentTarget)closeLb()});
document.addEventListener('keydown',e=>{
  if(e.key==='Escape')closeLb();
  if(e.key==='ArrowLeft')lbNav(-1);
  if(e.key==='ArrowRight')lbNav(1);
});
</script>
