<!-- COLECCIONES -->
<section class="sec" style="background:var(--ivory)" id="colecciones">
  <div class="sl">Colecciones</div>
  <h2 class="st">Tres universos,<br>una sola magia</h2>
  <p class="sp">Desde los primeros días de vida hasta el momento más especial. Alta costura para cada etapa.</p>
  <div class="ed-grid">
    <div class="ec">
      <img src="https://i.ibb.co/YwWcCz8/IMG-9722.jpg" alt="Niñas alta costura" loading="lazy">
